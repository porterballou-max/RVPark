@page
@model RVPark.Pages.Profile.VehicleModel
@{
    ViewData["Title"] = "My Vehicles";
}

<div class="app-container">
    <div class="main-content">
        <div class="profile-container card p-4 shadow-sm">
            <h4 class="mb-4">My Vehicles</h4>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }

            <!-- List of existing vehicles -->
            @if (Model.Vehicles.Any())
            {
                @foreach (var vehicle in Model.Vehicles)
                {
                    <div class="card mb-3">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h5>@vehicle.Year @vehicle.Make @vehicle.Model</h5>
                                    <p class="mb-0">License: <strong>@vehicle.LicensePlate</strong></p>
                                </div>
                                <form method="post" asp-page-handler="Delete" style="display:inline;">
                                    <input type="hidden" name="vehicleId" value="@vehicle.Id" />
                                    <button type="submit"
                                            class="btn btn-sm btn-danger"
                                            onclick="return confirm('Are you sure you want to remove this vehicle?');">
                                        Remove
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-info text-center py-4">
                    You don't have any vehicles on file yet.
                </div>
            }

            <!-- Add New Vehicle Button -->
            @if (Model.CanAddMoreVehicles)
            {
                <button class="btn btn-success mb-3" onclick="showAddForm()">
                    + Add New Vehicle
                </button>
            }

            <!-- Add New Vehicle Form (shown on demand) -->
            <div id="addVehicleForm" style="display: none;">
                <h5 class="mt-4">Add New Vehicle</h5>
                <form method="post" asp-page-handler="Add">
                    <div class="row">
                        <div class="col-md-3">
                            <label asp-for="NewVehicle.Year" class="form-label">Year</label>
                            <input asp-for="NewVehicle.Year" type="number" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="NewVehicle.Make" class="form-label">Make</label>
                            <input asp-for="NewVehicle.Make" class="form-control" />
                        </div>
                        <div class="col-md-5">
                            <label asp-for="NewVehicle.Model" class="form-label">Model</label>
                            <input asp-for="NewVehicle.Model" class="form-control" />
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-md-6">
                            <label asp-for="NewVehicle.LicensePlate" class="form-label">License Plate</label>
                            <input asp-for="NewVehicle.LicensePlate" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NewVehicle.Color" class="form-label">Color (optional)</label>
                            <input asp-for="NewVehicle.Color" class="form-control" />
                        </div>
                    </div>

                    <div class="mt-3">
                        <button type="submit" class="btn btn-success">Save Vehicle</button>
                        <button type="button" class="btn btn-secondary" onclick="hideAddForm()">Cancel</button>
                    </div>
                </form>
            </div>

            <div class="mt-4">
                <a asp-page="./Index" class="btn btn-secondary">Back to Profile</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showAddForm() {
            document.getElementById("addVehicleForm").style.display = "block";
        }

        function hideAddForm() {
            document.getElementById("addVehicleForm").style.display = "none";
        }

        function confirmDelete(vehicleId) {
            if (confirm("Are you sure you want to remove this vehicle?")) {
                window.location.href = `?handler=Delete&vehicleId=${vehicleId}`;
            }
        }
    </script>
}