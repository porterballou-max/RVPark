@page "{id:int}"
@model EditModel
@{
    ViewData["Title"] = "Edit Reservation";
}

<h2>Edit Reservation</h2>

<!--TODO: Enable crud for edits to reservation here-->
<form method="post">
    <input type="hidden" asp-for="reservationID" />

    <div class="mb-3">
        <label class="form-label">Start Date</label>
        <input asp-for="StartDate" type="date" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">End Date</label>
        <input asp-for="EndDate" type="date" class="form-control" />
    </div>

    <button asp-page-handler="CheckAvailability" type="submit" class="btn btn-primary">Check Availability</button>
    @if (Model.datesAccepted)
        {
            <button asp-page-handler="SaveChanges" type="submit" class="btn btn-success">Save Changes</button>
        }
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>

</form>

<div asp-validation-summary="All" class="text-danger"></div>