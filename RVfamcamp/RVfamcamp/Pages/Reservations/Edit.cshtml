@page "{id:int}"
@model EditModel
@{
    ViewData["Title"] = "Edit Reservation";
}

<h2>Edit Reservation</h2>

<!--TODO: Enable crud for edits to reservation here-->
<form method="post">

    <input type="hidden" asp-for="Reservation.reservationId" />

    <div class="mb-3">
        <label class="form-label">Start Date</label>
        <input asp-for="Reservation.startDate" type="date" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">End Date</label>
        <input asp-for="Reservation.endDate" type="date" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Confirmation Number</label>
        <input asp-for="Reservation.confirmationNumber" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Save Changes</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>

</form>