@page
@model CreateModel
@{
    ViewData["Title"] = "Create Reservation";
}

<h2>Create Reservation</h2>

<form method="post" asp-page-handler="CheckAvailability">

    <div class="mb-3">
        <label>Start Date</label>
        <input asp-for="StartDate" type="date" class="form-control" id="startDate"/>
    </div>

    <div class="mb-3">
        <label>End Date</label>
        <input asp-for="EndDate" type="date" class="form-control" id="endDate"/>
    </div>

    <button type="submit" class="btn btn-primary">Check Availability</button>
</form>

@if (Model.Available_Lots != null && Model.Available_Lots.Count > 0)
{
    <form method="post" asp-page-handler="CreateReservation">

        <input type="hidden" asp-for="StartDate" id="startDate" />
        <input type="hidden" asp-for="EndDate" id="endDate" />
        <input type="hidden" id="SelectedLotIds" name="SelectedLotIds" />

        <h4>Select One or More Lots</h4>

        @{
            var lotTypeDict = Model.Available_Lots_Types?
                .ToDictionary(t => t.LotTypeID);
        }

        <div class="lot-grid">
            @foreach (var lot in Model.Available_Lots
                            .OrderBy(l => lotTypeDict?[l.LotType]?.BasePrice ?? 0))
            {
                var lotType = lotTypeDict?[lot.LotType];

                <div class="lot-card"
                     data-lotid="@lot.LotId"
                     data-price="@(lotType?.BasePrice ?? 0)"
                     onclick="toggleLot(this)">

                    <h5>Lot @lot.LotNumber</h5>

                    <span class="badge bg-info">
                        @(lotType?.TypeName ?? "Unknown")
                    </span>

                    <p>
                        <strong>Price:</strong>
                        @(lotType != null ? $"${lotType.BasePrice} / night" : "N/A")
                    </p>

                    <p>
                        <strong>Size:</strong>
                        @(lotType?.LotSize ?? 0)
                    </p>
                </div>
            }
        </div>

        <div class="mt-3">
            <strong>Selected Lots:</strong> <span id="selectedCount">0</span><br />
            <strong>Total Price:</strong> $<span id="totalPrice">0</span>
        </div>

        <button type="submit" class="btn btn-success mt-3" onclick="return validateLots()">
            Create Reservation
        </button>
    </form>
}
else
{
    <p>No lots available for selected dates.</p>
}

<style>
    .lot-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 15px;
    }

    .lot-card {
        border: 1px solid #ccc;
        border-radius: 12px;
        padding: 15px;
        cursor: pointer;
        transition: 0.2s;
        background-color: white;
    }

        .lot-card:hover {
            transform: scale(1.03);
            border-color: #007bff;
        }

        .lot-card.selected {
            border: 2px solid #28a745;
            background-color: #e9f7ef;
        }
</style>

<script>
    const startInput = document.getElementById("startDate");
    const endInput = document.getElementById("endDate");

    const today = new Date().toISOString().split('T')[0];
    startInput.min = today;
    endInput.min = today;

    startInput.addEventListener("change", function() {
        if (startInput.value) {
            endInput.min = startInput.value;

            // If end date is before new start date, clear it
            if (endInput.value && endInput.value < startInput.value) {
                endInput.value = "";
            }
        }
    });

    endInput.addEventListener("change", function() {
        if (endInput.value) {
            startInput.max = endInput.value;

            // If start date is after end date, clear it
            if (startInput.value && startInput.value > endInput.value) {
                startInput.value = "";
            }
        }
    });
</script>
<script>
    let selectedLots = new Set();

    function getDayCount() {
        const start = new Date(document.getElementById("startDate").value);
        const end = new Date(document.getElementById("endDate").value);

        if (!start || !end || end <= start) return 0;

        const diffTime = end - start;
        return diffTime / (1000 * 60 * 60 * 24);
    }

    function toggleLot(element) {
        const lotId = element.dataset.lotid;
        const price = parseFloat(element.dataset.price);

        if (selectedLots.has(lotId)) {
            selectedLots.delete(lotId);
            element.classList.remove("selected");
        } else {
            selectedLots.add(lotId);
            element.classList.add("selected");
        }

        updateSummary();
    }

    function updateSummary() {
        const nights = getDayCount();
        let total = 0;

        document.querySelectorAll(".lot-card.selected").forEach(card => {
            total += parseFloat(card.dataset.price);
        });

        total *= nights;

        document.getElementById("selectedCount").innerText = selectedLots.size;
        document.getElementById("totalPrice").innerText = total.toFixed(2);

        // store selected IDs as comma-separated
        document.getElementById("SelectedLotIds").value =
            Array.from(selectedLots).join(",");
    }

    function validateLots() {
        if (selectedLots.size === 0) {
            alert("Please select at least one lot.");
            return false;
        }
        return true;
    }
</script>