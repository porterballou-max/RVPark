@page
@model ReservationsIndexModel
@{
    ViewData["Title"] = "Reservations";
}

<div class="reservations-header">
    <h2>Reservations</h2>
    <a class="btn btn-primary" asp-page="/Reservations/Create">+ New Reservation</a>
</div>

<table class="table table-striped table-hover mt-3">

    <thead class="table-dark">
        <tr>
          
            <th>startDate</th>
            <th>endDate</th>
            <th>confirmationNumber</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @if (Model.Reservations?.Any() == true)
        {
            foreach (var r in Model.Reservations)
            {
                <tr>
                    <td>@r.startDate.ToShortDateString()</td>
                    <td>@r.endDate.ToShortDateString()</td>
                    <td>@r.confirmationNumber</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" asp-page="/Reservations/Details" asp-route-id="@r.reservationId">View</a>
                        <a class="btn btn-sm btn-outline-secondary" asp-page="/Reservations/Edit" asp-route-id="@r.reservationId">Edit</a>
                        <a class="btn btn-sm btn-outline-danger" asp-page="/Reservations/Delete" asp-route-id="@r.reservationId">Delete</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center text-muted">
                    No reservations found.
                </td>
            </tr>
        }
    </tbody>

</table>