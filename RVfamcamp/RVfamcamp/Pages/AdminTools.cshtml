@page
@model AdminToolsModel
@{
    ViewData["Title"] = "Admin Tools";
}

@if (TempData["Flash.Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Flash.Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Flash.Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Flash.Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<h2>Employee Management</h2>

<div class="container mt-4">
    <div class="d-flex align-items-center mb-4">
        <h2 class="mb-0">User & Employee Management</h2>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white border-bottom-0 pt-3">
            <h6 class="text-muted text-uppercase fw-bold" style="font-size: 0.8rem; letter-spacing: 1px;">
                Filter User Records
            </h6>
        </div>
        <div class="card-body pt-0">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label small fw-bold text-secondary">Search by Name or Email</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white text-muted">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" asp-for="UserSearch" class="form-control border-start-0"
                               placeholder="e.g. John Miller or admin@rvpark.com">
                    </div>
                </div>

                <div class="col-md-3">
                    <label class="form-label small fw-bold text-secondary">Account Role</label>
                    <select asp-for="RoleFilter" class="form-select">
                        <option value="">All Account Types</option>
                        <option value="Admin">Administrators</option>
                        <option value="Employee">Employees</option>
                        <option value="Client">Clients</option>
                        <option value="Locked">Locked Accounts</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            Apply Filters
                        </button>
                        <a asp-page="./AdminTools" class="btn btn-outline-secondary">
                            Reset
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle bg-white mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-3">Full Name</th>
                    <th>Email Address</th>
                    <th>Status / Role</th>
                    <th class="text-center">Modify Permissions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td class="ps-3 fw-bold">@user.FirstName @user.LastName</td>
                        <td>@user.Email</td>
                        <td>
                            <span class="badge rounded-pill @(user.Role == "Locked" ? "bg-danger" : "bg-info text-dark")">
                                @user.Role
                            </span>
                        </td>
                        <td class="text-center">
                            @{
                                var currentAdminId = int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0");
                            }

                            @if (user.UserAccountId == currentAdminId)
                            {
                            }
                            else
                            {
                                <form method="post" asp-page-handler="UpdateRole" class="d-inline">
                                    <input type="hidden" name="id" value="@user.UserAccountId" />
                                    <div class="btn-group shadow-sm" role="group">
                                        <button name="newRole" value="Employee" class="btn btn-sm btn-outline-success" title="Set as Employee">Emp</button>
                                        <button name="newRole" value="Admin" class="btn btn-sm btn-outline-warning text-dark" title="Set as Admin">Admin</button>
                                        <button name="newRole" value="Client" class="btn btn-sm btn-outline-secondary" title="Demote to Client">Client</button>
                                        <button name="newRole" value="Locked" class="btn btn-sm btn-outline-danger" title="Lock Account">Lock</button>
                                    </div>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <hr class="my-5" />

    <div class="d-flex align-items-center mb-4">
        <h3 class="mb-0">Lot Pricing Configuration</h3>
    </div>

    <div class="row">
        <div class="col-md-9">
            <div class="card border-0 shadow-sm">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Site Type</th>
                                <th>Avg. Size (ft)</th>
                                <th>Current Rate</th>
                                <th style="width: 280px;">Update Base Price</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var type in Model.LotTypes)
                            {
                                <tr>
                                    <td class="ps-3"><strong>@type.TypeName</strong></td>
                                    <td>@type.LotSize'</td>
                                    <td class="text-success fw-bold">@type.BasePrice.ToString("C")</td>
                                    <td class="pe-3">
                                        <form method="post" asp-page-handler="UpdatePrice" class="input-group input-group-sm">
                                            <input type="hidden" name="lotTypeId" value="@type.LotTypeID" />
                                            <span class="input-group-text">$</span>
                                            <input type="number" step="0.01" name="newPrice" class="form-control" placeholder="0.00" required />
                                            <button class="btn btn-success" type="submit">Update</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>