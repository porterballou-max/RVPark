@page
@model AdminToolsModel
<h2>Employee Management</h2>

<table class="table table-hover mt-4">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Current Role</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model.Users)
        {
            <tr>
                <td>@user.FirstName @user.LastName</td>
                <td>@user.Email</td>
                <td>
                    <span class="badge @(user.Role == "Locked" ? "bg-danger" : "bg-info")">
                        @user.Role
                    </span>
                </td>
                <td>
                    <form method="post" asp-page-handler="UpdateRole" class="d-inline">
                        <input type="hidden" name="id" value="@user.UserAccountId" />

                        <button name="newRole" value="Employee" class="btn btn-sm btn-success">Make Employee</button>

                        <button name="newRole" value="Admin" class="btn btn-sm btn-warning">Make Admin</button>

                        <button name="newRole" value="Locked" class="btn btn-sm btn-danger">Lock Account</button>

                        <button name="newRole" value="Client" class="btn btn-sm btn-secondary">Demote to Client</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>